---
import "../styles/global.css";
import Header from "../components/Header.astro";
import { ClientRouter } from "astro:transitions";
import Analytics from '@vercel/analytics/astro'

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portfolio de Clement Pageaux, Software Engineer base a Paris." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-ambient" aria-hidden="true">
			<div class="ambient-grid"></div>
			<div class="ambient-orb orb-one"></div>
			<div class="ambient-orb orb-two"></div>
			<div class="ambient-ring"></div>
		</div>
		<Header />
		<main class="page-shell">
			<slot />
		</main>
		<script is:inline>
			const setupSiteMotion = () => {
				if (typeof window.__portfolioCleanup === "function") {
					window.__portfolioCleanup();
				}

				const body = document.body;
				const pageShell = document.querySelector(".page-shell");
				const sections = Array.from(
					document.querySelectorAll("main section[id][data-accent]")
				);
				const revealItems = Array.from(document.querySelectorAll("[data-reveal]"));
				const navLinks = Array.from(
					document.querySelectorAll(".header a[href^='#']")
				);
				const reduceMotion = window.matchMedia(
					"(prefers-reduced-motion: reduce)"
				).matches;
				const largeViewport = window.matchMedia("(min-width: 960px)").matches;
				const desktopPaged =
					largeViewport && pageShell instanceof HTMLElement;
				const defaultAccent =
					getComputedStyle(document.documentElement)
						.getPropertyValue("--accent")
						.trim() || "#60a5fa";
				const header = document.querySelector(".header");
				const headerOffset = () =>
					(header instanceof HTMLElement ? header.offsetHeight : 0) + 28;
				const scrollToSection = (section) => {
					if (!(section instanceof HTMLElement)) {
						return;
					}

					if (desktopPaged) {
						pageShell.scrollTo({
							top: section.offsetTop,
							behavior: "smooth",
						});
						return;
					}

					window.scrollTo({
						top: Math.max(0, section.offsetTop - headerOffset()),
						behavior: "smooth",
					});
				};
				const findClosestSectionIndex = () => {
					const scrollTop = desktopPaged ? pageShell.scrollTop : window.scrollY;
					const marker = scrollTop + window.innerHeight * 0.38;

					return sections.reduce((closestIndex, section, index) => {
						const distance = Math.abs(section.offsetTop - marker);
						const currentDistance = Math.abs(
							sections[closestIndex].offsetTop - marker
						);

						return distance < currentDistance ? index : closestIndex;
					}, 0);
				};

				const setActiveSection = (section) => {
					if (!section) {
						body.dataset.section = "default";
						body.style.setProperty("--active-accent", defaultAccent);
						navLinks.forEach((link) => link.classList.remove("is-active"));
						return;
					}

					const { id, dataset } = section;
					body.dataset.section = id;
					body.style.setProperty("--active-accent", dataset.accent || defaultAccent);

					navLinks.forEach((link) => {
						const isActive = link.getAttribute("href") === `#${id}`;
						link.classList.toggle("is-active", isActive);
						if (isActive) {
							link.setAttribute("aria-current", "location");
						} else {
							link.removeAttribute("aria-current");
						}
					});
				};

				const handleNavClick = (event) => {
					const href = event.currentTarget?.getAttribute("href");
					if (!href?.startsWith("#")) {
						return;
					}

					const target = document.querySelector(href);
					if (!(target instanceof HTMLElement)) {
						return;
					}

					event.preventDefault();
					scrollToSection(target);
				};

				if (!sections.length) {
					setActiveSection(null);
					window.__portfolioCleanup = () => {};
					return;
				}

				const initialSection =
					sections.find((section) => {
						const rect = section.getBoundingClientRect();
						const marker = window.innerHeight * 0.35;
						return rect.top <= marker && rect.bottom >= marker;
					}) || sections[0];

				if (reduceMotion) {
					revealItems.forEach((item) => item.classList.add("is-visible"));
					setActiveSection(initialSection);
					window.__portfolioCleanup = () => {};
					return;
				}

				const revealObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) {
								return;
							}

							entry.target.classList.add("is-visible");
							revealObserver.unobserve(entry.target);
						});
					},
					{
						threshold: 0.16,
						root: desktopPaged ? pageShell : null,
						rootMargin: "0px 0px -10% 0px",
					}
				);

				revealItems.forEach((item) => revealObserver.observe(item));

				const sectionObserver = new IntersectionObserver(
					(entries) => {
						const visibleSections = entries
							.filter((entry) => entry.isIntersecting)
							.sort((a, b) => b.intersectionRatio - a.intersectionRatio);

						if (visibleSections[0]) {
							setActiveSection(visibleSections[0].target);
						}
					},
					{
						root: desktopPaged ? pageShell : null,
						threshold: [0.2, 0.45, 0.7],
						rootMargin: "-15% 0px -35% 0px",
					}
				);

				sections.forEach((section) => sectionObserver.observe(section));
				navLinks.forEach((link) =>
					link.addEventListener("click", handleNavClick)
				);
				setActiveSection(initialSection);

				let pagingLock = false;
				let pagingTimeout = 0;
				let wheelDeltaBuffer = 0;
				let cleanupPaging = () => {};

				if (desktopPaged) {
					const unlockPaging = () => {
						pagingLock = false;
						wheelDeltaBuffer = 0;
						if (pagingTimeout) {
							window.clearTimeout(pagingTimeout);
							pagingTimeout = 0;
						}
					};

					const lockPaging = () => {
						unlockPaging();
						pagingLock = true;
						pagingTimeout = window.setTimeout(() => {
							pagingLock = false;
							pagingTimeout = 0;
						}, 900);
					};

					const handleSectionWheel = (event) => {
						if (
							pagingLock ||
							Math.abs(event.deltaY) < 4 ||
							event.ctrlKey ||
							event.metaKey ||
							event.altKey
						) {
							return;
						}

						const currentSection = event.currentTarget;
						if (!(currentSection instanceof HTMLElement)) {
							return;
						}

						const activeIndex = sections.indexOf(currentSection);
						if (activeIndex === -1) {
							return;
						}

						const sectionScroller =
							currentSection.querySelector("[data-section-scroll]");
						const internalScroller =
							event.target instanceof Element
								? event.target.closest("[data-section-scroll]")
								: null;
						const scrollElement =
							internalScroller instanceof HTMLElement &&
							currentSection.contains(internalScroller)
								? internalScroller
								: sectionScroller instanceof HTMLElement
									? sectionScroller
									: null;
						const canScrollInternally =
							scrollElement instanceof HTMLElement &&
							scrollElement.scrollHeight > scrollElement.clientHeight + 2;
						const atTop =
							!(scrollElement instanceof HTMLElement) ||
							scrollElement.scrollTop <= 1;
						const atBottom =
							!(scrollElement instanceof HTMLElement) ||
							scrollElement.scrollTop + scrollElement.clientHeight >=
								scrollElement.scrollHeight - 1;

						if (
							canScrollInternally &&
							((event.deltaY > 0 && !atBottom) || (event.deltaY < 0 && !atTop))
						) {
							wheelDeltaBuffer = 0;
							if (scrollElement !== internalScroller) {
								event.preventDefault();
								scrollElement.scrollTop += event.deltaY;
							}
							return;
						}

						wheelDeltaBuffer += event.deltaY;
						if (Math.abs(wheelDeltaBuffer) < 42) {
							return;
						}

						const targetIndex =
							wheelDeltaBuffer > 0 ? activeIndex + 1 : activeIndex - 1;
						const targetSection = sections[targetIndex];

						if (!targetSection) {
							wheelDeltaBuffer = 0;
							return;
						}

						event.preventDefault();
						wheelDeltaBuffer = 0;
						lockPaging();
						scrollToSection(targetSection);
					};

					const handleKeydown = (event) => {
						if (pagingLock) {
							return;
						}

						const nextKeys = ["PageDown", "ArrowDown", " "];
						const prevKeys = ["PageUp", "ArrowUp"];
						const isNext = nextKeys.includes(event.key);
						const isPrev = prevKeys.includes(event.key);

						if (!isNext && !isPrev) {
							return;
						}

						const activeIndex = findClosestSectionIndex();
						const activeSection = sections[activeIndex];
						const internalScroller =
							activeSection?.querySelector("[data-section-scroll]");
						const scrollElement =
							internalScroller instanceof HTMLElement
								? internalScroller
								: null;
						const canScrollInternally =
							scrollElement instanceof HTMLElement &&
							scrollElement.scrollHeight > scrollElement.clientHeight + 2;
						const atTop =
							!(scrollElement instanceof HTMLElement) ||
							scrollElement.scrollTop <= 1;
						const atBottom =
							!(scrollElement instanceof HTMLElement) ||
							scrollElement.scrollTop + scrollElement.clientHeight >=
								scrollElement.scrollHeight - 1;

						if (
							canScrollInternally &&
							((isNext && !atBottom) || (isPrev && !atTop))
						) {
							return;
						}

						const targetIndex = isNext ? activeIndex + 1 : activeIndex - 1;
						const targetSection = sections[targetIndex];

						if (!targetSection) {
							return;
						}

						event.preventDefault();
						lockPaging();
						scrollToSection(targetSection);
					};

					sections.forEach((section) =>
						section.addEventListener("wheel", handleSectionWheel, {
							passive: false,
						})
					);
					window.addEventListener("keydown", handleKeydown);

					cleanupPaging = () => {
						unlockPaging();
						sections.forEach((section) =>
							section.removeEventListener("wheel", handleSectionWheel)
						);
						window.removeEventListener("keydown", handleKeydown);
					};
				}

				window.__portfolioCleanup = () => {
					cleanupPaging();
					navLinks.forEach((link) =>
						link.removeEventListener("click", handleNavClick)
					);
					revealObserver.disconnect();
					sectionObserver.disconnect();
				};
			};

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", setupSiteMotion, {
					once: true,
				});
			} else {
				setupSiteMotion();
			}

			document.addEventListener("astro:page-load", setupSiteMotion);
		</script>
		<Analytics />
	</body>
</html>
