</header>

<style>
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 4rem;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background-color: rgba(17, 19, 26, 0.8);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .logo-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon {
    background-color: var(--accent);
    color: #000;
    font-weight: 800;
    font-size: 1.1rem;
    width: 30px;
    height: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 6px;
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.5px;
  }

  .nav {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .header {
      padding: 1rem 1.5rem;
    }
    .nav {
      display: none; /* Hide for mobile temporarily */
    }
  }
</style>
