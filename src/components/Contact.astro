---
const linkedinUrl = "https://www.linkedin.com/in/cl%C3%A9ment-pageaux-758377172/";
const email = "pageauxclement@gmail.com";
---

<section class="contact-section section-shell" id="contact" data-accent="#60a5fa">
  <div class="container" data-section-scroll>
    <div class="header-content text-center" data-reveal>
      <div class="section-badge center-badge">
        <span></span>
        <span></span>
      </div>
      <h2 class="section-title">Echangeons sur votre projet</h2>
      <p class="section-description">
        Disponible pour discuter developpement web, architecture applicative
        et evolution de produits web.<br />
        Le plus simple reste de m'ecrire ou de me contacter sur LinkedIn.
      </p>
    </div>

    <div class="contact-card" data-reveal="zoom" style="--stagger: 1;">
      <div class="contact-links">
        <a href={`mailto:${email}`} class="contact-btn email-btn">
          <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 512 512" height="1.5em" width="1.5em" xmlns="http://www.w3.org/2000/svg"><path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"></path></svg>
          {email}
        </a>
        <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="contact-btn linkedin-btn">
          <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 448 512" height="1.5em" width="1.5em" xmlns="http://www.w3.org/2000/svg"><path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"></path></svg>
          Voir mon profil LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    min-height: 100vh;
    padding: 8rem 4rem 4rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .container {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .text-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header-content {
    margin-bottom: 3.5rem;
    max-width: 650px;
  }

  .section-badge.center-badge {
    justify-content: center;
    margin-bottom: 2rem;
    gap: 1rem;
    display: flex;
  }

  .section-badge span {
    display: inline-block;
    width: 32px;
    height: 2px;
    background-color: var(--accent);
  }

  .section-title {
    font-size: 2.8rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
    letter-spacing: -0.5px;
  }

  .section-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .contact-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(10, 18, 32, 0.84));
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 3rem;
    width: 100%;
    max-width: 550px;
    box-shadow: 0 26px 56px rgba(2, 8, 23, 0.18);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    width: 100%;
    padding: 1.2rem;
    border-radius: 999px;
    font-size: 1.1rem;
    font-weight: 600;
    transition:
      transform 0.3s ease,
      background-color 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease,
      box-shadow 0.3s ease;
    text-decoration: none;
  }

  .email-btn {
    background:
      linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 36%, white));
    color: #04111f;
    box-shadow: 0 16px 32px color-mix(in srgb, var(--accent) 16%, transparent);
  }

  .email-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 38px color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .linkedin-btn {
    background-color: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }

  .linkedin-btn:hover {
    border-color: #0A66C2;
    background-color: rgba(10, 102, 194, 0.1);
    color: #0A66C2;
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .contact-section {
      padding: 6rem 1.5rem 2rem;
    }
    
    .section-title {
      font-size: 2.2rem;
    }
    
    .contact-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
