---
---

<section class="contact-section" id="contact">
  <div class="container">
    <div class="header-content text-center">
      <div class="section-badge center-badge">
        <span></span>
        <span></span>
      </div>
      <h2 class="section-title">Let's Work Together</h2>
      <p class="section-description">
        Have an opportunity, project, or just want to chat? I'd love to hear from you.<br />
        Send me a message and I'll get back to you shortly.
      </p>
    </div>

    <div class="contact-card">
      <div class="contact-links">
        <a href="mailto:contact@example.com" class="contact-btn email-btn">
          <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 512 512" height="1.5em" width="1.5em" xmlns="http://www.w3.org/2000/svg"><path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"></path></svg>
          Envoyer un email
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="contact-btn linkedin-btn">
          <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 448 512" height="1.5em" width="1.5em" xmlns="http://www.w3.org/2000/svg"><path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"></path></svg>
          Me contacter sur LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    min-height: 100vh;
    padding: 8rem 4rem 4rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .container {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .text-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header-content {
    margin-bottom: 3.5rem;
    max-width: 650px;
  }

  .section-badge.center-badge {
    justify-content: center;
    margin-bottom: 2rem;
    gap: 1rem;
    display: flex;
  }

  .section-badge span {
    display: inline-block;
    width: 32px;
    height: 2px;
    background-color: var(--accent);
  }

  .section-title {
    font-size: 2.8rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
    letter-spacing: -0.5px;
  }

  .section-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .contact-card {
    background-color: var(--pill-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 3rem;
    width: 100%;
    max-width: 550px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    width: 100%;
    padding: 1.2rem;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .email-btn {
    background-color: var(--accent);
    color: #000;
  }

  .email-btn:hover {
    background-color: var(--accent-hover);
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(0, 229, 255, 0.3);
  }

  .linkedin-btn {
    background-color: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }

  .linkedin-btn:hover {
    border-color: #0A66C2;
    background-color: rgba(10, 102, 194, 0.1);
    color: #0A66C2;
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .contact-section {
      padding: 6rem 1.5rem 2rem;
    }
    
    .section-title {
      font-size: 2.2rem;
    }
    
    .contact-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
