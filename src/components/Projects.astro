---
const projects = [
  {
    title: "Applications web en production",
    tag: "Production",
    description:
      "Conception, developpement et evolution d'applications web dans des environnements reels avec des contraintes de qualite, de delai et de maintenabilite.",
    tech: "Architecture, conception, developpement, evolution",
    image: "/project-img.png",
    primaryLabel: "Voir le parcours",
    primaryLink: "#experience",
    secondaryLabel: "Me contacter",
    secondaryLink: "#contact",
  },
  {
    title: "Qualite logicielle & maintenance",
    tag: "Qualite",
    description:
      "Amelioration continue, corrections, stabilite et maintenabilite des solutions livrees, avec une attention particuliere portee a la robustesse.",
    tech: "Tests, correction, maintenance evolutive, stabilite",
    image: "/project-img.png",
    primaryLabel: "Voir le parcours",
    primaryLink: "#experience",
    secondaryLabel: "LinkedIn",
    secondaryLink: "https://www.linkedin.com/in/cl%C3%A9ment-pageaux-758377172/",
  },
  {
    title: "Analyse & livraison",
    tag: "Delivery",
    description:
      "Traduction des besoins metier en solutions techniques pragmatiques, en lien avec les equipes impliquees pour fiabiliser les livraisons.",
    tech: "Analyse, collaboration, delivery, pragmatisme",
    image: "/project-img.png",
    primaryLabel: "Discutons-en",
    primaryLink: "#contact",
    secondaryLabel: "LinkedIn",
    secondaryLink: "https://www.linkedin.com/in/cl%C3%A9ment-pageaux-758377172/",
  },
];
---

<section class="projects-section section-shell" id="projects" data-accent="#fb7185">
  <div class="container" data-section-scroll>
    <div class="header-content" data-reveal>
      <div class="section-badge"><span></span> Interventions</div>
      <h2 class="section-title">Types de projets</h2>
      <p class="section-description">
        Quelques types de sujets sur lesquels j'interviens aujourd'hui, en restant
        volontairement generique sur les contextes clients et produits.
      </p>
    </div>

    <div class="projects-grid">
      {
        projects.map((project, index) => (
          <div class="project-card" data-reveal="zoom" style={`--stagger: ${index + 1};`}>
            <div class="card-image">
              <img src={project.image} alt={project.title} loading="lazy" />
            </div>
            <div class="card-content">
              <span class="tag">{project.tag}</span>
              <h3 class="card-title">{project.title}</h3>
              <p class="card-desc">{project.description}</p>
              <div class="card-tech">{project.tech}</div>

              <div class="card-actions">
                <a href={project.primaryLink} class="btn-sm btn-primary">
                  {project.primaryLabel}
                </a>
                <a href={project.secondaryLink} class="btn-sm btn-outline" target={project.secondaryLink.startsWith("http") ? "_blank" : undefined} rel={project.secondaryLink.startsWith("http") ? "noopener noreferrer" : undefined}>
                  <svg
                    stroke="currentColor"
                    fill="currentColor"
                    stroke-width="0"
                    viewBox="0 0 496 512"
                    height="1em"
                    width="1em"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3.7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9 1.6 1 3.6.7 4.3-.7.7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3.7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3.7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z" />
                  </svg>
                  {project.secondaryLabel}
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    min-height: 100vh;
    padding: 8rem 4rem 4rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .container {
    max-width: 1200px;
    width: 100%;
  }

  .header-content {
    margin-bottom: 2.5rem;
    max-width: 650px;
  }

  .section-badge {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    letter-spacing: 0.5px;
  }

  .section-badge span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--accent);
  }

  .section-title {
    font-size: 2.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
    letter-spacing: -0.5px;
  }

  .section-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .project-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(15, 23, 42, 0.84));
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    transition:
      transform 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;
    box-shadow: 0 24px 50px rgba(2, 8, 23, 0.18);
  }

  .project-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.8;
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--accent);
    box-shadow: 0 30px 60px color-mix(in srgb, var(--accent) 10%, rgba(2, 8, 23, 0.35));
  }

  .card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 1.5rem;
  }

  .tag {
    display: inline-block;
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
    font-size: 0.75rem;
    padding: 0.3rem 0.8rem;
    border-radius: 99px;
    margin-bottom: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1.2rem;
  }

  .card-tech {
    background-color: rgba(0, 0, 0, 0.18);
    padding: 0.6rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    border: 1px solid rgba(148, 163, 184, 0.12);
  }

  .card-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-sm {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    transition:
      transform 0.3s ease,
      background-color 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease,
      box-shadow 0.3s ease;
    flex: 1;
    justify-content: center;
  }

  .btn-primary {
    background:
      linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 38%, white));
    color: #04111f;
    box-shadow: 0 12px 24px color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 28px color-mix(in srgb, var(--accent) 24%, transparent);
  }

  .btn-outline {
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--text-secondary);
  }

  .btn-outline:hover {
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .projects-section {
      padding: 6rem 1.5rem 2rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
