            <h3 class="skill-name">{skill.name}</h3>
            <span class="skill-category">{skill.category}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills-section {
    min-height: 100vh;
    padding: 8rem 4rem 4rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .container {
    max-width: 1200px;
    width: 100%;
  }

  .header-content {
    margin-bottom: 3.5rem;
    max-width: 650px;
  }

  .section-badge {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    letter-spacing: 0.5px;
  }

  .section-badge span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--accent);
  }

  .section-title {
    font-size: 2.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
    letter-spacing: -0.5px;
  }

  .section-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .skills-grid {
    display: grid;
    /* Adapting columns to show ~5 per row on large screens as per design */
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .skill-card {
    background-color: var(--pill-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .skill-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
  }

  .skill-icon-wrapper {
    background-color: var(--bg-color);
    width: 64px;
    height: 64px;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .skill-name {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .skill-category {
    background-color: rgba(255, 255, 255, 0.03);
    color: var(--text-secondary);
    font-size: 0.8rem;
    padding: 0.5rem 1.2rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 768px) {
    .skills-section {
      padding: 6rem 1.5rem 2rem;
    }
    .skills-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    }
  }
</style>
